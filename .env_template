# Required: LLM API key (OpenAI or compatible endpoint)
OPENAI_API_KEY = "sk-..."

# Optional: custom endpoint (defaults to OpenAI)
OPENAI_BASE_URL = "https://api.openai.com/v1"

# Optional: model name (defaults to gpt-4o)
MODEL_NAME = "gpt-4o"

# Optional: separate vision model (defaults to MODEL_NAME)
# VISION_API_KEY = ""
# VISION_BASE_URL = ""
# VISION_MODEL_NAME = ""

# Optional: self-healing and cache settings
# AUTO_HEAL_ENABLED = "true"
# AUTO_HEAL_TRIGGER_THRESHOLD = "3"
# DEFAULT_TIMEOUT = "10"
# CACHE_ENABLED = "true"
# CACHE_TTL_DAYS = "7"
